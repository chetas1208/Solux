# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGODB_DB=solux

# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TEXT_MODEL=MiniMax-M2

# ─── Modular / Mojo (optional) ───────────────────────────────────────────────
# If set, the agent can call this OpenAI-compatible endpoint for local reranking
MODULAR_MODEL_ENDPOINT=

# ─── Solar data (real APIs — leave blank to mark source unavailable) ─────────
NREL_API_KEY=              # https://developer.nrel.gov/signup/
# PVGIS is free/open — no key needed but you can set a custom endpoint
PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_2

# ─── Local raster / vector datasets (paths to downloaded files) ──────────────
# Global Solar Atlas GHI raster (GeoTIFF downloaded from https://globalsolaratlas.info)
GLOBAL_SOLAR_ATLAS_DATA_DIR=/data/global-solar-atlas
# US PVDB shapefile (https://eerscmap.usgs.gov/uspvdb/)
USPVDB_DATA_DIR=/data/uspvdb
# GEBCO bathymetry (https://www.gebco.net/data_and_products/gridded_bathymetry_data/)
GEBCO_DATA_DIR=/data/gebco
# Copernicus Marine Service config dir (https://marine.copernicus.eu/)
COPERNICUS_MARINE_CONFIG=/data/copernicus

# ─── Maps / 3D Earth ─────────────────────────────────────────────────────────
# Backend keys (server-side health probes — never expose in browser)
GOOGLE_MAPS_API_KEY=
CESIUM_ION_TOKEN=
MAPTILER_KEY=
GOOGLE_3D_TILES_ENABLED=false

# Frontend public keys (browser-safe only)
NUXT_PUBLIC_MAP_PROVIDER=cesium
NUXT_PUBLIC_ENABLE_3D_EARTH=true
# Get free token: https://ion.cesium.com/tokens — set BOTH to the same value
NUXT_PUBLIC_CESIUM_ION_TOKEN=
CESIUM_ION_TOKEN=
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=   # same value as GOOGLE_MAPS_API_KEY
NUXT_PUBLIC_GOOGLE_3D_TILES_ENABLED=false
NUXT_PUBLIC_MAPTILER_KEY=
MAPTILER_KEY=                        # same value as NUXT_PUBLIC_MAPTILER_KEY (backend probe)
NUXT_PUBLIC_MAP_FALLBACK=maplibre

# ─── DigitalOcean ────────────────────────────────────────────────────────────
DIGITALOCEAN_SPACES_ENDPOINT=https://<region>.digitaloceanspaces.com
DIGITALOCEAN_SPACES_BUCKET=solux-reports
DIGITALOCEAN_SPACES_KEY=
DIGITALOCEAN_SPACES_SECRET=

# ─── API runtime ─────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ─── Data lake + model pipeline ──────────────────────────────────────────────
DATA_ROOT=/data/solux
DATASET_VERSION=v0.1
SOLUX_DATASET_PREFIX=datasets/solux-site-screening/v0.1
SOLUX_OUTPUT_PREFIX=outputs/solux-site-screening/v0.1
SOLUX_RUN_PREFIX=runs/solux-site-screening/v0.1
SOLUX_MODEL_ENDPOINT=https://via-provide-roman-annual.trycloudflare.com
# Swagger UI: https://via-provide-roman-annual.trycloudflare.com/docs
SOLUX_MODEL_ENDPOINT_AUTH=
SOLUX_MODEL_TIMEOUT_MS=120000
SOLUX_MODEL_BATCH_SIZE=256
SOLUX_MODEL_MAX_RETRIES=2
CLEAN_CONFIRM=
CLEAN_RAW=false
DO_UPLOAD=true
RUN_MODEL_ANALYSIS=true
PUSH_MODEL_OUTPUTS=true
