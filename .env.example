# Solux model server configuration
# Copy to .env and adjust for your workstation.

MODEL_CACHE_DIR=/data/models/solux
SOLUX_OUTPUT_DIR=/data/models/solux/outputs
REGISTRY_JSON=ops/model-cache/model-registry.json

# Hugging Face token (needed for gated model downloads, not runtime unless loading gated weights)
HF_TOKEN=

# GPU / loading policy
MODEL_GPU=
CUDA_VISIBLE_DEVICES=
SOLUX_MAX_LOADED_MODELS=1
PRELOAD_REQUIRED_MODELS=false

# Optional download flags (used by ops/model-cache scripts)
DOWNLOAD_OPTIONAL_LARGE=false
DOWNLOAD_LOCAL_LLM=false
LOCAL_CRITIC_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
COMPUTE_LARGE_CHECKSUMS=false

# Server
HOST=0.0.0.0
PORT=8088
LOG_LEVEL=info

# Auto-unload idle models (seconds)
AUTO_UNLOAD_AFTER_SECONDS=600
