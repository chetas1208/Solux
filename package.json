{
  "name": "solux",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --filter @solux/web dev",
    "dev:all": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @solux/api dev",
    "build": "pnpm --filter @solux/web build",
    "start": "pnpm --filter @solux/web start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,vue,json,md}\"",
    "db:indexes": "tsx ops/scripts/setup-indexes.ts",
    "db:seed": "tsx ops/scripts/seed.ts",
    "data:sync": "bash ops/run_solux_data_model_sync.sh",
    "pipeline:discover": "bash ops/spaces/discover-solux-paths.sh",
    "pipeline:ingest": "tsx ops/spaces/ingest-catalog-to-mongo.ts",
    "pipeline:model": "tsx ops/model-analysis/run-full-model-pipeline.ts",
    "pipeline:full": "bash ops/run_full_solux_pipeline.sh",
    "test:e2e": "tsx ops/tests/run-solux-e2e-queries.ts",
    "showcase:ensure": "tsx ops/showcase/ensure-showcase-projects.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
